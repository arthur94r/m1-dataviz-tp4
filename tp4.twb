      <aliases enabled='yes' />
      <column caption='15% Q4' datatype='string' name='[Calculation_0188204404715521]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([pourcentage_exprimes]) &gt; 15 THEN &quot;Oui&quot; ELSE &quot;Non&quot; END' />
      </column>
      <column caption='Taux abstention (%)' datatype='real' name='[Calculation_0188204405837826]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(1 - [taux_participation] / 100) * 100' />
      </column>
      <column caption='Taux bulletins blancs (%)' datatype='real' name='[Calculation_0188204409110531]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([bulletins_blancs]) / SUM([votants]) * 100' />
      </column>
      <column caption='Taux bulletins nuls (%)' datatype='real' name='[Calculation_0188204410466308]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([bulletins_nuls]) / SUM([votants]) * 100' />
      </column>
      <column caption='elections_municipales_2026.csv' datatype='table' name='[__tableau_internal_object_id__].[elections_municipales_2026.csv_F400CA8A4D5E4750AA4282F44D8455F8]' role='measure' type='quantitative' />
