            <column-instance column='[Calculation_0188204405837826]' derivation='Sum' name='[sum:Calculation_0188204405837826:qk]' pivot='key' type='quantitative' />
            <column caption='Taux Participation' datatype='real' name='[taux_participation]' role='measure' type='quantitative' />
            <column caption='Tour' datatype='integer' name='[tour]' role='measure' type='quantitative' />
          </datasource-dependencies>
