          <datasource-dependencies datasource='federated.1nb7jdh1cevxzq12vlryh1shzjff'>
            <column caption='Taux abstention (%)' datatype='real' name='[Calculation_0188204405837826]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(1 - [taux_participation] / 100) * 100' />
            </column>
            <column-instance column='[Calculation_0188204405837826]' derivation='Avg' name='[avg:Calculation_0188204405837826:qk]' pivot='key' type='quantitative' />
